#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
declare -a changed_skills=()

has_changed_skill() {
  local candidate="$1"
  local skill

  if [ "${#changed_skills[@]}" -eq 0 ]; then
    return 1
  fi

  for skill in "${changed_skills[@]}"; do
    if [ "$skill" = "$candidate" ]; then
      return 0
    fi
  done

  return 1
}

while IFS= read -r -d '' path; do
  case "$path" in
    skills/*/*)
      skill_name="${path#skills/}"
      skill_name="${skill_name%%/*}"
      ;;
    *)
      continue
      ;;
  esac

  if ! has_changed_skill "$skill_name"; then
    changed_skills+=("$skill_name")
  fi
done < <(git diff --cached --name-only --diff-filter=ACDMRT -z -- skills/)

if [ "${#changed_skills[@]}" -eq 0 ]; then
  exit 0
fi

staged_tree="$(mktemp -d)"
trap 'rm -rf "$staged_tree"' EXIT
git checkout-index --all --prefix="$staged_tree/"

declare -a skills_to_validate=()
for skill_name in "${changed_skills[@]}"; do
  if [ -d "$staged_tree/skills/$skill_name" ]; then
    skills_to_validate+=("$skill_name")
  fi
done

if [ "${#skills_to_validate[@]}" -eq 0 ]; then
  exit 0
fi

echo "Validating staged skills: ${skills_to_validate[*]}"
(
  cd "$staged_tree"
  "$repo_root/scripts/validate-skills.sh" "${skills_to_validate[@]}"
)
